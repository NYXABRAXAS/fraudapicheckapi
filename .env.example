APP_NAME=Fraud Detection API
APP_ENV=local
APP_HOST=0.0.0.0
APP_PORT=8000
DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5432/frauddb
REDIS_URL=redis://localhost:6379/0
JWT_SECRET_KEY=change-me-in-production
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=60
RATE_LIMIT_PER_MINUTE=60
VELOCITY_WINDOW_MINUTES=15
VELOCITY_THRESHOLD=3
RULES_CONFIG_PATH=app/core/rules.json
ENABLE_KAFKA=false
KAFKA_BOOTSTRAP_SERVERS=localhost:9092
KAFKA_TOPIC_FRAUD_DECISIONS=fraud.decisions
